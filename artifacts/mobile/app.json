{
  "expo": {
    "name": "INVESTRY",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "updates": {
      "url": "https://u.expo.dev/02968d16-c91f-4aa0-a178-c2f13c1e33b5",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "requestHeaders": {
        "expo-channel-name": "production"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.investry.app",
      "buildNumber": "52",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.investry.app",
      "versionCode": 39,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon-foreground.png",
        "backgroundColor": "#FFFFFF"
      },
      "statusBar": {
        "barStyle": "light-content",
        "backgroundColor": "transparent",
        "translucent": true
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://investry.app/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-updates",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#A9821E"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FDFBF7",
          "dark": {
            "backgroundColor": "#121212"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "17.0"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "owner": "investrytest2",
    "extra": {
      "eas": {
        "projectId": "02968d16-c91f-4aa0-a178-c2f13c1e33b5"
      }
    }
  }
}
