modules = ["nodejs-24", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["stripe:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["eas-cli"]

[userenv]

[userenv.shared]
FREE_ACCESS_PLAN = "off"
LAUNCH_ACCESS_UNTIL = "2026-12-31T23:59:59Z"
PERMANENT_FREE_EMAILS = "yousseftarek2772@gmail.com,youssefabdallaa007@gmail.com"
